{
  "manifest_version": 2,
  "name": "RE Toolkit",
  "version": "4.0.0",
  "description": "Reverse engineering toolkit for web applications",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "storage",
    "clipboardWrite",
    "activeTab",
    "tabs",
    "downloads"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html"
  }
}
